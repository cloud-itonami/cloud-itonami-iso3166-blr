#:culture{:url "https://en.wikipedia.org/wiki/Kontusz_sash", :id "blr.craft.slutsk-sash", :kind :craft, :name-local "слуцкі пояс", :country "BLR", :retrieved-at "2026-07-17", :summary "Kontusz sashes manufactured in Slutsk (now in Belarus), known as Slutsk sashes; woven with silk and gold thread, they were the most desirable and most expensive sashes of Polish-Lithuanian noble dress.", :name "Slutsk sash", :url-provenance :wikipedia-en}
#:culture{:url "https://en.wikipedia.org/wiki/Kupala_Night", :id "blr.festival.kupala-night", :kind :festival, :name-local "Купалле", :country "BLR", :retrieved-at "2026-07-17", :summary "Slavic summer-solstice folk holiday with night rituals of water, fire and herbs, celebrated on the night of 6-7 July in Belarus; researchers note the holiday is preserved in its most archaic form by the Belarusians.", :name "Kupala Night", :url-provenance :wikipedia-en}
